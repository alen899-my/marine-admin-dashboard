# ==========================================
# DATABASE
# ==========================================

# Your MongoDB connection string. 
# You can get this from your MongoDB Atlas dashboard under "Connect" -> "Drivers".
# Format: mongodb+srv://<username>:<password>@<cluster-url>/?appName=<AppName>
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>"

# The name of the specific database you want to connect to within your MongoDB cluster.
MONGODB_DB="your_database_name_here"


# ==========================================
# AUTHENTICATION / JWT
# ==========================================

# A long, random string used to securely sign JSON Web Tokens (JWT).
# You can generate a strong secret by running `openssl rand -base64 32` in your terminal.
JWT_SECRET="your_generated_jwt_secret_here"

# Secret used by your auth provider (e.g., NextAuth.js) to encrypt cookies and tokens.
# Generate this exactly like the JWT_SECRET above.
AUTH_SECRET="your_generated_auth_secret_here"

# Set to true if hosting behind a trusted proxy (like Vercel, Railway, etc.) 
# or if you are bypassing host validation in NextAuth.
AUTH_TRUST_HOST=true


# ==========================================
# NEXT.JS APPLICATION
# ==========================================

# The base URL of your application. 
# Use http://localhost:3000 for local development, and your actual domain in production.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"


# ==========================================
# STORAGE / FILE UPLOADS
# ==========================================

# The read/write token for your Vercel Blob storage.
# Find this in your Vercel project settings under "Storage".
BLOB_READ_WRITE_TOKEN="your_vercel_blob_token_here"

# Defines where uploaded files should be stored. 
# Options include local, vercel-blob, or s3.
UPLOAD_PROVIDER=local


# ==========================================
# EMAIL / SMTP SERVICES
# ==========================================

# The email address that will act as the sender for transactional emails.
EMAIL_FROM="your_sender_email@example.com"

# The App Password or SMTP password for the sender email address.
# Note: For Gmail, use an "App Password", not your standard account password.
EMAIL_PASS="your_email_app_password_here"

# ==========================================
# ANALYTICS (Umami)
# ==========================================

# Toggle to enable or disable analytics tracking (true/false)
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# The URL where your Umami analytics script is hosted.
NEXT_PUBLIC_UMAMI_URL="https://analytics.parkora.io/script.js"

# Your unique Umami Website ID for tracking.
NEXT_PUBLIC_UMAMI_ID="your_umami_website_id_here"